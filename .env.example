# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=smart_attendance

# Face Recognition Settings
CONFIDENCE_THRESHOLD=70
FACE_RECOGNITION_MODEL=small
FACE_RECOGNITION_JITTERS=1
FACE_CASCADE_PATH=haarcascade/haarcascade_frontalface_default.xml

# Face Detection (Cascade Classifier)
CASCADE_SCALE_FACTOR=1.1
CASCADE_MIN_NEIGHBORS=4
CASCADE_MIN_SIZE=60

# Camera Settings
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS_PROCESS_EVERY=2

# Registration Settings
REGISTRATION_NUM_IMAGES=40
REGISTRATION_NO_FACE_THRESHOLD=120

# File Paths
DATASET_DIR=dataset
ENCODINGS_FILE=encodings.pkl
ATTENDANCE_EXPORT_DIR=attendance
LOG_DIR=logs

# UI Configuration
WINDOW_WIDTH=1160
WINDOW_HEIGHT=720
BLINK_FREQUENCY=800
CLOCK_UPDATE_INTERVAL=1000

# Colors (Cyber-terminal palette)
COLOR_BG=#080b12
COLOR_BG2=#0d1220
COLOR_BG3=#111827
COLOR_BORDER=#1e293b
COLOR_CYAN=#00d4ff
COLOR_CYAN_DIM=#0ea5c9
COLOR_GREEN=#00ff9d
COLOR_GREEN_DIM=#059669
COLOR_AMBER=#ffb300
COLOR_RED=#ff3b5c
COLOR_PURPLE=#8b5cf6
COLOR_TEXT=#e2e8f0
COLOR_TEXT2=#64748b
COLOR_TEXT3=#94a3b8
COLOR_WHITE=#ffffff

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE_NAME=smart_attendance.log
